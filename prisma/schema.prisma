// EMAIL SYSTEM - BUILDER & CAMPAIGNS
// ============================================================================

/// Email content - can be a template or a one-off email
/// This is the core of the Email Builder Studio
model Email {
  id              String        @id @default(cuid())
  name            String        // Internal name for reference
  description     String?       // Optional description
  
  // Content
  subject         String        // Email subject line
  previewText     String?       // Preview text shown in email client
  htmlContent     String        @db.Text
  textContent     String?       @db.Text // Plain text fallback
  designJson      Json?         // Builder state for re-editing (blocks, layout, etc.)
  
  // Classification
  emailType       EmailType     @default(TRANSACTIONAL)
  category        String?       // "newsletter", "announcement", "notification", "marketing", "welcome"
  aiClassification EmailType?   // AI suggested classification
  aiConfidence    Float?        // AI confidence score 0-1
  
  // Template settings
  isTemplate      Boolean       @default(false)  // Is this a reusable template?
  variables       String[]      @default([])     // ["userName", "venueName", etc.]
  thumbnailUrl    String?       // Preview image for template library
  
  // Usage tracking
  useCount        Int           @default(0)      // How many times used in campaigns
  lastUsedAt      DateTime?
  
  // Ownership
  isSystem        Boolean       @default(false)  // System templates can't be deleted
  isDefault       Boolean       @default(false)  // Default template for a category
  venueId         String?       // Null = available to all venues
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  venue           Venue?        @relation(fields: [venueId], references: [id])
  creator         User          @relation(fields: [createdBy], references: [id])
  campaigns       EmailCampaign[]  // Campaigns that use this email
  generations     EmailGeneration[] // AI generations that created this email
  
  @@index([isTemplate])
  @@index([category])
  @@index([venueId])
  @@index([isSystem])
  @@index([createdBy])
  @@map("emails")
}

/// Saved segments for reusable recipient targeting
model EmailSegment {
  id              String        @id @default(cuid())
  name            String        // e.g., "All Sydney Staff", "Managers + Admins"
  description     String?
  
  // Segment rules (stored as JSON)
  rules           Json          // { roles: [...], venueIds: [...], status: [...], customConditions: [...] }
  
  // Stats
  userCount       Int           @default(0)     // Cached count of matching users
  lastCalculated  DateTime?                     // When count was last updated
  
  // Ownership
  isSystem        Boolean       @default(false) // System segments for all users
  venueId         String?       // Null = available to all, set = venue-specific
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  venue           Venue?        @relation(fields: [venueId], references: [id])
  creator         User          @relation(fields: [createdBy], references: [id])
  campaigns       EmailCampaign[]  // Campaigns using this segment
  
  @@index([venueId])
  @@index([isSystem])
  @@index([createdBy])
  @@map("email_segments")
}

/// Email campaigns for broadcasting messages to users
/// Now links to Email model instead of containing content directly
model EmailCampaign {
  id              String        @id @default(cuid())
  name            String        // Campaign name for reference
  
  // Link to email content (from Email Builder Studio)
  emailId         String
  email           Email         @relation(fields: [emailId], references: [id])
  
  // Optional overrides (if you want to customize without changing the email)
  customSubject   String?       // Override subject line
  customHtml      String?       @db.Text // Override HTML content
  
  // Targeting rules
  targetRoles     String[]      @default([])  // ["ADMIN", "MANAGER", "STAFF"]
  targetVenueIds  String[]      @default([])  // Specific venues (empty = all based on permissions)
  targetStatus    String[]      @default(["ACTIVE"]) // ["ACTIVE", "INACTIVE", "PENDING"]
  targetUserIds   String[]      @default([])  // Specific users (for manual selection)
  segmentId       String?       // Link to saved segment
  segment         EmailSegment? @relation(fields: [segmentId], references: [id])
  
  // Stats
  recipientCount  Int           @default(0)
  sentCount       Int           @default(0)
  deliveredCount  Int           @default(0)
  openedCount     Int           @default(0)
  clickedCount    Int           @default(0)
  bouncedCount    Int           @default(0)
  unsubscribedCount Int         @default(0)
  complaintCount  Int           @default(0)
  
  // Status & Scheduling
  status          CampaignStatus @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  startedSendingAt DateTime?
  completedAt     DateTime?
  
  // Ownership & Audit
  createdBy       String
  venueId         String?       // Null = system-wide (admin only), set = venue-specific
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  creator         User          @relation("EmailCampaignCreator", fields: [createdBy], references: [id])
  venue           Venue?        @relation(fields: [venueId], references: [id])
  recipients      EmailRecipient[]
  analytics       EmailCampaignAnalytics?
  
  @@index([status])
  @@index([emailId])
  @@index([venueId])
  @@index([createdBy])
  @@index([scheduledAt])
  @@index([segmentId])
  @@map("email_campaigns")
}

/// Individual recipient tracking for each campaign
model EmailRecipient {
  id              String              @id @default(cuid())
  campaignId      String
  userId          String
  email           String
  name            String?
  
  // Delivery status
  status          EmailRecipientStatus @default(PENDING)
  brevoMessageId  String?             // Brevo's message ID for tracking
  
  // Tracking timestamps
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  openedCount     Int                 @default(0)
  clickedAt       DateTime?
  clickedCount    Int                 @default(0)
  clickedUrls     Json?               // Array of clicked URLs with timestamps
  unsubscribedAt  DateTime?
  complainedAt    DateTime?
  
  // Error tracking
  error           String?             @db.Text
  bounceReason    String?
  bounceType      String?             // "hard", "soft", "spam"
  
  // Device/Client info (from webhooks)
  deviceType      String?             // "desktop", "mobile", "tablet"
  emailClient     String?             // "gmail", "outlook", etc.
  ipAddress       String?
  userAgent       String?
  
  // Relations
  campaign        EmailCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id])
  
  @@unique([campaignId, userId])
  @@unique([campaignId, email])
  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([email])
  @@map("email_recipients")
}

/// Campaign analytics aggregation
model EmailCampaignAnalytics {
  id              String        @id @default(cuid())
  campaignId      String        @unique
  
  // Aggregate rates
  openRate        Float         @default(0)    // Percentage
  clickRate       Float         @default(0)    // Percentage
  clickToOpenRate Float         @default(0)    // Clicks / Opens
  bounceRate      Float         @default(0)    // Percentage
  unsubscribeRate Float         @default(0)    // Percentage
  complaintRate   Float         @default(0)    // Percentage
  
  // Device breakdown
  desktopOpens    Int           @default(0)
  mobileOpens     Int           @default(0)
  tabletOpens     Int           @default(0)
  unknownDeviceOpens Int        @default(0)
  
  // Email client breakdown
  clientBreakdown Json?         // { "gmail": 50, "outlook": 30, ... }
  
  // Time-based analytics
  opensByHour     Json?         // { "0": 5, "1": 2, ... } 0-23 hours
  opensByDay      Json?         // { "Mon": 10, "Tue": 15, ... }
  clicksByHour    Json?         // { "0": 3, "1": 1, ... }
  clicksByDay     Json?         // { "Mon": 5, "Tue": 8, ... }
  
  // Geographic (if available from IP)
  opensByCountry  Json?         // { "AU": 50, "US": 30, ... }
  
  // Link tracking
  topClickedLinks Json?         // [{ "url": "...", "clicks": 10 }, ...]
  
  // Timeline data (for charts)
  hourlyTimeline  Json?         // [{ "hour": "2024-01-01T10:00", "opens": 5, "clicks": 2 }, ...]
  
  updatedAt       DateTime      @updatedAt
  
  campaign        EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  @@map("email_campaign_analytics")
}

/// Reusable email templates (DEPRECATED - use Email model with isTemplate=true)
/// Keeping for backward compatibility during migration
model EmailTemplate {
  id              String        @id @default(cuid())
  name            String
  description     String?
  category        String?       // "announcement", "notification", "marketing", "transactional"
  thumbnailUrl    String?       // Preview image for template library
  
  // Content
  subject         String
  htmlContent     String        @db.Text
  textContent     String?       @db.Text
  designJson      Json?         // Builder state for re-editing
  
  // Variables supported in this template
  variables       String[]      @default([]) // ["userName", "venueName", etc.]
  
  // Usage tracking
  useCount        Int           @default(0)
  lastUsedAt      DateTime?
  
  // Ownership
  isSystem        Boolean       @default(false)  // System templates can't be deleted
  isDefault       Boolean       @default(false)  // Default template for a category
  venueId         String?       // Null = available to all
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  venue           Venue?        @relation(fields: [venueId], references: [id])
  creator         User          @relation(fields: [createdBy], references: [id])
  
  @@index([venueId])
  @@index([category])
  @@index([isSystem])
  @@map("email_templates")
}

/// AI generation history (for learning/improvement)
model EmailGeneration {
  id              String        @id @default(cuid())
  prompt          String        @db.Text
  generatedHtml   String        @db.Text
  generatedSubject String?
  generatedText   String?       @db.Text
  
  // AI model info
  modelUsed       String        // "gpt-4", "gpt-3.5-turbo", etc.
  tokensUsed      Int?
  generationTime  Int?          // milliseconds
  
  // User feedback
  rating          Int?          // 1-5 stars
  feedback        String?       @db.Text
  wasUsed         Boolean       @default(false)  // Was this generation used?
  emailId         String?       // If used, which email was created from this
  
  // Metadata
  tone            String?       // "professional", "friendly", "urgent", "celebratory"
  targetAudience  String?
  emailType       EmailType?    // Suggested classification
  
  createdBy       String
  createdAt       DateTime      @default(now())
  
  // Relations
  user            User          @relation(fields: [createdBy], references: [id])
  email           Email?        @relation(fields: [emailId], references: [id])
  
  @@index([createdBy])
  @@index([modelUsed])
  @@index([wasUsed])
  @@index([emailId])
  @@map("email_generations")
}

/// User email preferences for marketing vs transactional
model UserEmailPreference {
  id                  String    @id @default(cuid())
  userId              String    @unique
  
  // Global preferences
  receiveMarketing    Boolean   @default(true)
  receiveTransactional Boolean  @default(true)
  receiveAnnouncements Boolean  @default(true)
  receiveReminders    Boolean   @default(true)
  
  // Unsubscribe tracking
  unsubscribedAt      DateTime?
  unsubscribedFrom    String[]  @default([]) // ["MARKETING", "ANNOUNCEMENTS", "ALL"]
  unsubscribeReason   String?
  
  // Engagement tracking (for segmentation)
  lastOpenedAt        DateTime?
  lastClickedAt       DateTime?
  totalOpens          Int       @default(0)
  totalClicks         Int       @default(0)
  
  // Timestamps
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([receiveMarketing])
  @@index([receiveTransactional])
  @@map("user_email_preferences")
}

/// Email webhooks log (for debugging and audit)
model EmailWebhookEvent {
  id              String    @id @default(cuid())
  eventType       String    // "sent", "delivered", "opened", "clicked", "bounce", "spam", "unsubscribed"
  brevoMessageId  String?
  campaignId      String?
  recipientEmail  String
  
  // Raw event data
  eventData       Json
  
  // Processing status
  processed       Boolean   @default(false)
  processedAt     DateTime?
  error           String?
  
  // Timestamps
  receivedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  @@index([eventType])
  @@index([brevoMessageId])
  @@index([campaignId])
  @@index([recipientEmail])
  @@index([processed])
  @@map("email_webhook_events")
}

// Email-specific enums
enum EmailType {
  TRANSACTIONAL
  MARKETING
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENDING
  SENT
  PARTIALLY_SENT
  FAILED
  CANCELLED
}

enum EmailRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  UNSUBSCRIBED
  COMPLAINED
  FAILED
  SKIPPED
}
